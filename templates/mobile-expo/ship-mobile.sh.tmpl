#!/usr/bin/env bash
# ship-mobile.sh — deploy Expo project:
#   1) Build APK (preview) → scp to <slug>.<DEPLOY_DOMAIN>/app.apk (sideload)
#   2) Build AAB (production) → eas submit → Play Console Internal Testing
#
# ENV yêu cầu (Mac worker set sẵn):
#   SSH_KEY, SSH_USER, AWS_HOST           — cho APK subdomain hosting
#   ANDROID_SERVICE_ACCOUNT_PATH          — cho EAS Submit Play Store
#   EAS_ACCOUNT                           — dùng eas login sẵn
#   DEPLOY_DOMAIN                          — domain gốc (default mirotic.io)
set -euo pipefail

SLUG="$(basename $(pwd) | sed 's/^mirotic-//')"
DOMAIN="${SLUG}.${DEPLOY_DOMAIN:-mirotic.io}"
BASE_URL="https://${DOMAIN}"

echo "🚀 ship-mobile: ${SLUG}"
echo ""

# ─── Phase 0: đảm bảo EAS project tồn tại ─────────────────────────
# app.json ship kèm placeholder {EAS_PROJECT_ID}; eas build cần projectId THẬT.
# Gỡ placeholder (+ updates OTA không cần cho preview APK) rồi eas init --force tạo project.
# Idempotent: app.json đã có projectId thật (không còn placeholder) thì skip.
if grep -q "{EAS_PROJECT_ID}" app.json 2>/dev/null; then
  echo "🔧 [0/3] eas init — tạo/link EAS project…"
  node -e 'const fs=require("fs");const j=JSON.parse(fs.readFileSync("app.json","utf8"));if(j.expo&&j.expo.extra&&j.expo.extra.eas)delete j.expo.extra.eas.projectId;if(j.expo&&j.expo.updates)delete j.expo.updates;fs.writeFileSync("app.json",JSON.stringify(j,null,2));'
  eas init --force --non-interactive
fi

# ─── Phase 1: PREVIEW APK → APK subdomain ─────────────────────────
echo "📦 [1/3] EAS Build preview (APK internal)…"
eas build --profile preview --platform android --non-interactive --wait

APK_URL=$(eas build:list --limit 1 --status finished --json --non-interactive | jq -r '.[0].artifacts.buildUrl')
if [[ -z "$APK_URL" || "$APK_URL" == "null" ]]; then
  echo "❌ Không lấy được APK URL từ EAS"
  exit 1
fi

curl -L "$APK_URL" -o "app.apk"
[[ -s "app.apk" ]] || { echo "❌ APK rỗng"; exit 1; }

SSH_OPTS="-i ${SSH_KEY} -o StrictHostKeyChecking=accept-new"
ssh $SSH_OPTS "${SSH_USER}@${AWS_HOST}" "sudo mkdir -p /var/www/mirotic-apps/${SLUG} && sudo chown ${SSH_USER}:${SSH_USER} /var/www/mirotic-apps/${SLUG}"
scp $SSH_OPTS "app.apk" "${SSH_USER}@${AWS_HOST}:/var/www/mirotic-apps/${SLUG}/app.apk"

ssh $SSH_OPTS "${SSH_USER}@${AWS_HOST}" bash <<CADDY
set -e
BLOCK="/etc/caddy/vhosts/${SLUG}.caddy"
if [[ ! -f "\$BLOCK" ]]; then
  sudo mkdir -p /etc/caddy/vhosts
  sudo tee "\$BLOCK" > /dev/null <<EOF
${DOMAIN} {
  root * /var/www/mirotic-apps/${SLUG}
  @apk path /app.apk /app.aab
  file_server @apk
  header /app.apk Content-Type "application/vnd.android.package-archive"
  header /app.apk Content-Disposition "attachment; filename=${SLUG}.apk"
}
EOF
  sudo systemctl reload caddy || sudo docker exec caddy caddy reload --config /etc/caddy/Caddyfile
fi
CADDY
rm -f app.apk
echo "✓ APK: ${BASE_URL}/app.apk"
echo ""

# ─── Phase 2/3: PRODUCTION AAB → Play Store (OPTIONAL, best-effort) ───
# CHỈ chạy khi service account đã cấu hình (eas.json không còn placeholder + file key tồn tại).
# App mới CHƯA có trên Play Console phải upload tay lần đầu (chính sách Google) → submit sẽ fail;
# nên Phase này KHÔNG chặn deploy — APK sideload ở trên đã là deploy thành công.
PLAY_LINE=""
SA_PATH="$(node -e 'try{let p=(require("./eas.json").submit?.production?.android?.serviceAccountKeyPath)||"";p=p.replace(/^~/,process.env.HOME||"~");console.log(p)}catch(e){console.log("")}')"
if [[ -n "$SA_PATH" && "$SA_PATH" != *"{ANDROID_SERVICE_ACCOUNT"* && -f "$SA_PATH" ]]; then
  echo "📦 [2/3] EAS Build production (AAB) + submit Play Internal (best-effort)…"
  if eas build --profile production --platform android --non-interactive --wait \
     && eas submit --profile production --platform android --non-interactive; then
    PLAY_LINE="  • Play Internal: https://play.google.com/console (Test → Internal Testing → ${SLUG})"
    echo "✓ Play Console Internal Testing updated"
  else
    echo "⚠️  Play submit bỏ qua/lỗi (app mới cần upload tay lần đầu) — APK sideload vẫn OK"
  fi
else
  echo "⏭️  [2/3] Bỏ qua Play Store (chưa cấu hình service account) — chỉ host APK sideload"
fi

echo ""
echo "✓ Deployed:"
echo "  • APK sideload:  ${BASE_URL}/app.apk"
[[ -n "$PLAY_LINE" ]] && echo "$PLAY_LINE"
echo "${BASE_URL}/app.apk"
