# ============================================================================
# Copy file này thành .env rồi điền. Cách lấy TỪNG giá trị: xem SETUP.md.
# [BẮT BUỘC] = phải có để chạy.  [tuỳ chọn] = bỏ trống cũng được.
# .env KHÔNG commit, KHÔNG vào image (xem .gitignore / .dockerignore).
# ============================================================================

# ===== AWS (quản lý EC2 + Postgres + đích deploy) — SETUP.md §1 =====
AWS_ACCESS_KEY_ID=          # [BẮT BUỘC]
AWS_SECRET_ACCESS_KEY=      # [BẮT BUỘC]
AWS_REGION=ap-southeast-1   # [BẮT BUỘC] mã region của instance
INSTANCE_ID=               # [BẮT BUỘC] id EC2, dạng i-0abc123...
SSH_KEY=~/.ssh/your-key.pem # [BẮT BUỘC] đường dẫn private key .pem
SSH_USER=ubuntu            # [BẮT BUỘC] ubuntu (Ubuntu AMI) hoặc ec2-user (Amazon Linux)
AWS_HOST=                  # [BẮT BUỘC] public IP/domain của EC2 (URL deploy)

# ===== Database (Postgres dùng chung) — SETUP.md §2 =====
DATABASE_URL=              # để TRỐNG → setup.sh tự dựng & điền. Hoặc trỏ Tailscale IP.
DB_NAME=dailyloop          # [tuỳ chọn]
DB_USER=dailyloop          # [tuỳ chọn]
DB_PASS=                   # [tuỳ chọn] trống = tự sinh ngẫu nhiên

# ===== GitHub (tạo repo private + CI/CD) — SETUP.md §3 =====
GITHUB_TOKEN=              # [BẮT BUỘC] fine-grained PAT (quyền: Administration, Contents, Workflows, Secrets)
GITHUB_OWNER=              # [BẮT BUỘC] username/org tạo repo

# ===== Claude Code (executor) — SETUP.md §4 =====
ANTHROPIC_API_KEY=         # [BẮT BUỘC] hoặc dùng gói Max (xem SETUP.md §4)
USE_REAL_CLAUDE=false      # true khi đã wire gstack trong container

# ===== Ollama (Prototyper LLM, native trên Mac) — SETUP.md §5 =====
USE_REAL_OLLAMA=false      # true = Prototyper dùng model thật chọn/sáng tạo ý tưởng
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3-coder:30b

# ===== App config (có default, đổi tuỳ ý) =====
PORT=4321
BASE_URL=http://localhost:4321   # → https://<machine>.<tailnet>.ts.net nếu dùng Tailscale
HMAC_SECRET=change-me-please      # trống/placeholder → setup.sh tự sinh
MORNING_AT=07:00                 # giờ sinh ý tưởng mới mỗi ngày
POLL_INTERVAL_MIN=5              # poller quét DB mỗi N phút
NICHES=developer tools,productivity,AI/LLM apps,data viz
BACKLOG_DIR=./backlog

# ===== Prototyper — nguồn phụ — SETUP.md §6 =====
PH_TOKEN=                  # [tuỳ chọn] Product Hunt API token
GITHUB_TRENDING_LANG=      # [tuỳ chọn] vd typescript
GITHUB_TRENDING_SINCE=daily

# ===== Email thông báo (Resend) — SETUP.md §7 =====
RESEND_API_KEY=            # [tuỳ chọn] trống = ghi ra ./data/outbox/*.html
EMAIL_FROM=daily-loop@yourdomain.com
EMAIL_TO=

# ===== Tailscale (khuyến nghị, thay vì mở port public) — SETUP.md §8 =====
TS_AUTHKEY=               # [tuỳ chọn] auth key để nối EC2+Mac vào tailnet
